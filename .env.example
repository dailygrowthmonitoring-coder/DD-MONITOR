# Supabase — project URL (server-side)
SUPABASE_URL=

# Supabase — service role key (SERVER-SIDE ONLY; never ship to the browser)
# Used by the ingest API and watchdog cron to bypass RLS for report writes.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — anon key (server-side RSC reads, respects RLS)
SUPABASE_ANON_KEY=

# Supabase — public URL for browser client (same value as SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase — public anon key for browser client (same value as SUPABASE_ANON_KEY)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Shared secret sent in the x-ingest-key header by Apps Script and the admin upload page.
# Rotate: update Vercel env + Apps Script Script Properties together.
INGEST_SECRET=

# Secret sent by Vercel Cron in the Authorization header for the watchdog route
CRON_SECRET=

# Brevo (Sendinblue) API key for outbound notification emails
# Brevo Dashboard → SMTP & API → API Keys → Create API key
BREVO_API_KEY=

# Fallback email recipient if notification_recipients in app_settings is empty
NOTIFY_FALLBACK_RECIPIENT=

# ── Two-factor authentication ──────────────────────────────────────────────────

# Verified sender address for 2FA code emails (must be approved in Brevo → Senders & IPs)
BREVO_FROM_EMAIL=

# How long (seconds) a 2FA code is valid. Default is 60.
TWO_FACTOR_CODE_TTL_SECONDS=60

# Browser-exposed copy for the countdown timer on the 2FA page. Must equal TWO_FACTOR_CODE_TTL_SECONDS.
NEXT_PUBLIC_TWO_FACTOR_CODE_TTL_SECONDS=60
